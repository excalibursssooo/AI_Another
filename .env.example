# Local infra ports
POSTGRES_PORT=5432
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Frontend telemetry (MVP)
TELEMETRY_ENABLED=true

# Postgres credentials for docker-compose
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=companion

# App backend switches
MEMORY_REPOSITORY=postgres
MEMORY_VECTOR=qdrant
MEMORY_EXTRACTION_BACKEND=zhipu
MEMORY_EXTRACTION_RUNTIME=langchain
MEMORY_EXTRACTION_MODEL_NAME=glm-4.7-flash
POSTGRES_DSN=postgresql://postgres:postgres@localhost:5432/companion
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=companion_memory

# Emotion backend
EMOTION_BACKEND=zhipu
EMOTION_RUNTIME=langchain
ZAI_API_KEY=
EMOTION_MODEL_NAME=glm-4.7-flash
CHAT_RUNTIME=langchain
CHAT_MODEL_NAME=glm-4.7-flash
AGENT_CREATOR_MODEL_NAME=glm-4.7-flash
EMOTION_POLICY_PATH=configs/emotion_policy.example.json

# Runtime persistence for non-memory modules
AGENT_REPOSITORY=json
AGENT_JSON_PATH=data/agents.json
TASK_REPOSITORY=json
TASK_JSON_PATH=data/tasks.json
CONVERSATION_REPOSITORY=json
CONVERSATION_JSON_PATH=data/conversations.json
FEED_REPOSITORY=json
FEED_JSON_PATH=data/posts.json
FEED_RUNTIME=langchain
FEED_MODEL_NAME=glm-4.7-flash
FEED_GENERATION_ENABLED=true
FEED_GENERATION_INTERVAL_SECONDS=300
FEED_AGENT_COOLDOWN_SECONDS=1800
