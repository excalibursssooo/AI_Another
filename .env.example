# App
APP_ENV=development
DEV_USER_ID=u001
NEXT_PUBLIC_DEMO_USER_ID=u001

# Database
DATABASE_URL=file:./data/another-world.sqlite

# AI
# mock keeps local development offline and deterministic.
AI_PROVIDER=mock
CHAT_MODEL=
MEMORY_MODEL=
AGENT_CREATOR_MODEL=
WORLD_CREATOR_MODEL=
FEED_MODEL=

# Provider keys, only required when AI_PROVIDER is changed.
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
MINIMAX_API_KEY=
MINIMAX_BASE_URL=

# Feature flags
ENABLE_MEMORY_ASYNC=true
ENABLE_FEED=true
ENABLE_TOOLS=false
ENABLE_AUTH=false
